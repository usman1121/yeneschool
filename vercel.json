{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(modules|modules.html|contact|contact.html|demo|demo.html|book|book.html|privacy|privacy.html|terms|terms.html|cookie-policy|cookie-policy.html)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, follow"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/modules", "destination": "/" },
    { "source": "/modules.html", "destination": "/" },
    { "source": "/contact", "destination": "/" },
    { "source": "/contact.html", "destination": "/" },
    { "source": "/demo", "destination": "/" },
    { "source": "/demo.html", "destination": "/" },
    { "source": "/book", "destination": "/" },
    { "source": "/book.html", "destination": "/" },
    { "source": "/privacy", "destination": "/" },
    { "source": "/privacy.html", "destination": "/" },
    { "source": "/terms", "destination": "/" },
    { "source": "/terms.html", "destination": "/" },
    { "source": "/cookie-policy", "destination": "/" },
    { "source": "/cookie-policy.html", "destination": "/" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
