{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/modules", "destination": "/modules/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/demo", "destination": "/demo/index.html" },
    { "source": "/vs-others", "destination": "/vs-others/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/cookie-policy", "destination": "/cookie-policy/index.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
